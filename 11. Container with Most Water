class Solution:
    def maxArea(self, height: List[int]) -> int:
        max=0
        i=0
        j=len(height)-1
        while i<j:
            if abs(i-j)*(min(height[i],height[j]))>max:
                max=abs(i-j)*(min(height[i],height[j]))
            if height[i]<=height[j]:
                i+=1
            else:
                j-=1
        return max
