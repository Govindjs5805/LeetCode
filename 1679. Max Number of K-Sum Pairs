class Solution:
    def maxOperations(self, nums: List[int], k: int) -> int:
        count=0
        n=len(nums)
        nums.sort()
        i=0
        j=n-1

        while i<j:
            sum=nums[i]+nums[j]
            if sum==k:
                count+=1
                i+=1
                j-=1
            elif sum<k:
                i+=1
            else:
                j-=1
        return count
