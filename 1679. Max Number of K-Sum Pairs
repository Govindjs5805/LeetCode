class Solution:
    def maxOperations(self, nums: List[int], k: int) -> int:
        maxo=0
        n=len(nums)
        for i in range(n):
            for j in range(i+1,n):
                if nums[i]+nums[j]==k:
                    maxo+=1
                    nums.pop(j)
                    n-=1
                    break
        return maxo
