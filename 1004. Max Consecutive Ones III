Given a binary aray nums and an integer k, return the maximum number of consecutive 1's in the array if you can flip at most k 0's.

class Solution:
    def longestOnes(self, nums: List[int], k: int) -> int:
        left=0
        right=0
        zero=0
        ans=0
        n=len(nums)
        for right in range(n):
            if nums[right]==0:
                zero+=1
            while zero>k:
                if nums[left]==0:
                    zero-=1
                left+=1
            ans=max(ans,right-left+1)
        return ans
