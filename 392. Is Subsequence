class Solution:
    def isSubsequence(self, s: str, t: str) -> bool:
        l1=list(s)
        l2=list(t)
        i=0
        if len(l1)==0:
            return True
        if len(l2)==0:
            return False
        for j in range(len(l2)):
            if l2[j]==l1[i]:
                i+=1
            if i==len(l1):
                return True
        if i==len(l1):
            return True
        else: 
            return False
