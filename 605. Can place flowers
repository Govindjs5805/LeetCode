class Solution:
    def canPlaceFlowers(self, flowerbed: List[int], n: int) -> bool:
        final=[]
        for i in range(len(flowerbed)):
            if i==0:
                if flowerbed[i]==0:
                    if len(flowerbed)>1:
                        if flowerbed[i+1]==0:
                            flowerbed[i]=1
                            final.append(1)
                    else:
                        final.append(1)
            elif i==(len(flowerbed)-1):
                if flowerbed[i]==0:
                    if flowerbed[i-1]==0:
                        flowerbed[i]=1
                        final.append(1)
            else:
                if flowerbed[i]==0:
                    if flowerbed[i-1]==0 and flowerbed[i+1]==0:
                        flowerbed[i]=1
                        final.append(1)
        if n<=len(final):
            return True
        else:
            return False
